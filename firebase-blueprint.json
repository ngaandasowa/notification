{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "username": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "bio": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "email"]
    },
    "Card": {
      "title": "Card",
      "description": "A notification-style card.",
      "type": "object",
      "properties": {
        "cardId": { "type": "string" },
        "userId": { "type": "string" },
        "message": { "type": "string" },
        "senderName": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "likesCount": { "type": "number" },
        "gotItCount": { "type": "number" },
        "sharesCount": { "type": "number" },
        "dislikesCount": { "type": "number" },
        "viewsCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "imageUrl": { "type": "string" }
      },
      "required": ["cardId", "userId", "message", "senderName", "createdAt"]
    },
    "CommunityPost": {
      "title": "CommunityPost",
      "description": "A post in the community section.",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userAvatar": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "likes": { "type": "number" }
      },
      "required": ["postId", "userId", "content", "createdAt"]
    },
    "Stats": {
      "title": "Stats",
      "description": "Global application statistics.",
      "type": "object",
      "properties": {
        "totalUsers": { "type": "number" },
        "totalViews": { "type": "number" },
        "totalCards": { "type": "number" }
      }
    },
    "Interaction": {
      "title": "Interaction",
      "description": "A user's interaction with a card.",
      "type": "object",
      "properties": {
        "interactionId": { "type": "string" },
        "userId": { "type": "string" },
        "cardId": { "type": "string" },
        "type": { "type": "string", "enum": ["like", "gotIt", "share", "dislike"] }
      },
      "required": ["interactionId", "userId", "cardId", "type"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "cards/{cardId}": {
      "schema": "Card",
      "description": "Notification cards."
    },
    "interactions/{interactionId}": {
      "schema": "Interaction",
      "description": "User interactions with cards."
    },
    "community/{postId}": {
      "schema": "CommunityPost",
      "description": "Community posts."
    },
    "stats/global": {
      "schema": "Stats",
      "description": "Global stats."
    }
  }
}
